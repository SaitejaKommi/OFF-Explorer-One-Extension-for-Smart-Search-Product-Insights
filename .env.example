# Application Configuration
DEBUG=False

# DuckDB Configuration
# For Canada-only dataset use: data/products_canada.parquet
# For full dataset use: data/products.parquet  
DUCKDB_PATH=:memory:
PARQUET_GLOB=data/products_canada.parquet

# Server Configuration
HOST=0.0.0.0
PORT=8000

# CORS Configuration - Allow extension origin in production
CORS_ORIGINS=["*"]

# Feature Flags
SLM_ENABLED=False
SLM_MODEL=phi3:mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT=30.0
OFF_API_TIMEOUT=8.0

# Search Defaults
DEFAULT_RESULT_LIMIT=20
MAX_RELAXATION_STEPS=3

# Context Configuration
CONTEXT_MAX_HISTORY=10
